name: Build Voting
on:
  push:
    branches:
      - master
    paths:
      - 'voting/**'
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}
      - name: Build
        run: docker build -t ${{ secrets.DOCKER_USERNAME }}/voting:latest ./voting
      - name: Push
        run: docker push ${{ secrets.DOCKER_USERNAME }}/voting:latest
